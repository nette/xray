{
	"name": "nette/xray-dev",
	"require": {
		"php": ">=8.2",
		"nette/application": "^3.2",
		"nette/forms": "^3.2",
		"nette/caching": "^3.4",
		"nette/neon": "~3.4.7",
		"latte/latte": "~3.1.2",
		"phpstan/phpstan": "~2.1.40"
	},
	"require-dev": {
		"nette/tester": "^2.6",
		"nette/phpstan-rules": "dev-master",
		"phpstan/extension-installer": "^1.4"
	},
	"autoload": {
		"psr-4": {
			"Nette\\Xray\\": "src/"
		}
	},
	"bin": ["bin/xray"],
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	},
	"config": {
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	}
}
